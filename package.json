{
  "keywords": ["sigil", "var", "variable"],
  "author": "Herman Bergwerf",
  "name": "sigil",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Getters and setters wrapped into a single function.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bergwerf/sigil"
  },

  "type": "module",
  "main": "./dist/sigil.js",
  "types": "./dist/sigil.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/sigil.js",
      "types": "./dist/sigil.d.ts"
    }
  },

  "scripts": {
    "prepublishOnly": "tsc",
    "build": "tsc",
    "check": "tsc --noEmit",
    "check_example": "tsc --project tsconfig.example.json",
    "run_example": "node --experimental-transform-types ./example/basic.ts"
  },

  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.13.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^26",
    "typescript": "^7"
  },
  "peerDependencies": {
    "typescript": ">=5"
  }
}
